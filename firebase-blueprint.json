{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with avatar, custom username, banner customized fields",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Email address of the owner" },
        "name": { "type": "string", "description": "Display name or nickname" },
        "avatarUrl": { "type": "string", "description": "Web URL to user avatar photo" },
        "language": { "type": "string", "description": "User preferred interface language" },
        "bannerType": { "type": "string", "description": "Banner type option none/color/image" },
        "bannerValue": { "type": "string", "description": "Hex code or Image URL value" }
      },
      "required": ["email", "name", "avatarUrl"]
    },
    "Book": {
      "title": "Book",
      "description": "Information parsed from web lookup and cached",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID or self link generated for search" },
        "title": { "type": "string", "description": "The title of the book" },
        "author": { "type": "string", "description": "The author of the book" },
        "coverUrl": { "type": "string", "description": "Cover asset URL" },
        "rating": { "type": "number", "description": "Average ratings score" },
        "snippet": { "type": "string", "description": "Synopses description text" },
        "tags": { "type": "array", "description": "Parsed genre keys" },
        "buyLink": { "type": "string", "description": "Purchase link if parsed" },
        "buyLinkText": { "type": "string", "description": "Label text for buy link" },
        "createdAt": { "type": "string", "description": "Creation timestamp placeholder" }
      },
      "required": ["id", "title", "author", "coverUrl", "rating", "snippet", "tags", "createdAt"]
    },
    "BookReview": {
      "title": "BookReview",
      "description": "Evaluation of a book, including notes, rating, and status",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique key or Firestore document ID" },
        "title": { "type": "string", "description": "Title of the book evaluated" },
        "author": { "type": "string", "description": "Author of the book" },
        "status": { "type": "string", "enum": ["LENDO", "CONCLUÍDO", "PAUSADO"], "description": "Reading progress status" },
        "rating": { "type": "number", "description": "Star rating out of 5" },
        "coverUrl": { "type": "string", "description": "Web URL to book cover graphic" },
        "reviewText": { "type": "string", "description": "Textual write-up review comments" },
        "tags": { "type": "array", "description": "Array of categorized hashtag strings" },
        "isFavorite": { "type": "boolean", "description": "Marker if saved as favorite" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Review registration timestamp" },
        "userId": { "type": "string", "description": "The Firestore UID of the owner" }
      },
      "required": [
        "id",
        "title",
        "author",
        "status",
        "rating",
        "coverUrl",
        "reviewText",
        "tags",
        "isFavorite",
        "createdAt",
        "userId"
      ]
    },
    "BookQuote": {
      "title": "BookQuote",
      "description": "User notes or quotes written down synchronously",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique key or Firestore document ID" },
        "bookTitle": { "type": "string", "description": "The title of the reference book" },
        "quoteText": { "type": "string", "description": "The text content of the quote/note" },
        "page": { "type": "string", "description": "The optional page number" },
        "chapter": { "type": "string", "description": "The optional chapter name/number" },
        "savedAt": { "type": "string", "format": "date-time", "description": "Quote registration timestamp" },
        "userId": { "type": "string", "description": "The Firestore UID of the owner" }
      },
      "required": [
        "id",
        "bookTitle",
        "quoteText",
        "savedAt",
        "userId"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user accounts with custom profiles"
    },
    "/users/{userId}/reviews/{reviewId}": {
      "schema": "BookReview",
      "description": "Underlying storage for each user's book review documents"
    },
    "/users/{userId}/quotes/{quoteId}": {
      "schema": "BookQuote",
      "description": "Storage for each user's notes and quotes"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Information stored on search grounding"
    }
  }
}
